# Application
APP_NAME=Media Finder
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8091
PUID=1000
PGID=1000
# Replace before starting with APP_ENV=production (for example: openssl rand -hex 32)
APP_SECRET_KEY=replace-with-a-random-64-character-secret
DATABASE_URL=sqlite:////config/media-finder.db
LOG_LEVEL=INFO

# Search and provider runtime
SEARCH_QUERY_MIN_LENGTH=2
SEARCH_QUERY_MAX_LENGTH=200
SEARCH_MAX_PROVIDERS=10
SEARCH_PROVIDER_TIMEOUT_SECONDS=5
SEARCH_RESULT_TOKEN_TTL_SECONDS=900
SEARCH_RESULT_STORE_MAX_ITEMS=2000
SEARCH_RATE_LIMIT_REQUESTS=20
SEARCH_RATE_LIMIT_WINDOW_SECONDS=60
SEARCH_HISTORY_PAGE_SIZE=25
PROVIDER_RATE_LIMIT_REQUESTS=20
PROVIDER_RATE_LIMIT_WINDOW_SECONDS=60
PROVIDER_CACHE_MAX_ITEMS=512

# TMDB
TMDB_ENABLED=true
TMDB_API_KEY=
TMDB_AUTH_MODE=bearer
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
TMDB_LANGUAGE=pt-BR
TMDB_REGION=ES
TMDB_TIMEOUT_SECONDS=10
TMDB_CACHE_TTL_SECONDS=3600
TMDB_MAX_RESULTS=20
TMDB_MAX_CONCURRENCY=3
TMDB_ALLOW_HTTP=false

# Metadata flow
METADATA_SEARCH_MIN_LENGTH=2
METADATA_SEARCH_MAX_LENGTH=200
METADATA_RESULT_TOKEN_TTL_SECONDS=900
METADATA_RESULT_STORE_MAX_ITEMS=1000
METADATA_RATE_LIMIT_REQUESTS=30
METADATA_RATE_LIMIT_WINDOW_SECONDS=60
METADATA_SHOW_SPECIALS=false

# qBittorrent
QBITTORRENT_URL=http://qbittorrent:8080
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=
QBITTORRENT_CATEGORY_MOVIE=movies
QBITTORRENT_CATEGORY_SERIES=series
QBITTORRENT_CATEGORY_ANIME=
QBITTORRENT_CATEGORY_OTHER=
QBITTORRENT_CONNECT_TIMEOUT_SECONDS=5
QBITTORRENT_OPERATION_TIMEOUT_SECONDS=15
QBITTORRENT_HEALTH_TIMEOUT_SECONDS=5

# Prowlarr
PROWLARR_ENABLED=true
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=
PROWLARR_TIMEOUT_SECONDS=15
PROWLARR_MAX_RESULTS=200
PROWLARR_CACHE_TTL_SECONDS=60
PROWLARR_MAX_CONCURRENCY=3

# Jackett
JACKETT_ENABLED=true
JACKETT_URL=http://jackett:9117
JACKETT_API_KEY=
JACKETT_TIMEOUT_SECONDS=20
JACKETT_MAX_RESULTS=200
JACKETT_CACHE_TTL_SECONDS=60
JACKETT_MAX_CONCURRENCY=3
JACKETT_INDEXERS=all

GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_FOLDER_URL=
GOOGLE_DRIVE_API_KEY=
GOOGLE_DRIVE_TIMEOUT_SECONDS=10
GOOGLE_DRIVE_MAX_RESULTS=100

# Torrentio
TORRENTIO_ENABLED=false
TORRENTIO_MANIFEST_URL=
TORRENTIO_TIMEOUT_SECONDS=20
TORRENTIO_CACHE_TTL_SECONDS=120
TORRENTIO_MAX_RESULTS=200
TORRENTIO_MAX_CONCURRENCY=2

# MediaFusion
MEDIAFUSION_ENABLED=false
MEDIAFUSION_MANIFEST_URL=
MEDIAFUSION_TIMEOUT_SECONDS=20
MEDIAFUSION_CACHE_TTL_SECONDS=120
MEDIAFUSION_MAX_RESULTS=200
MEDIAFUSION_MAX_CONCURRENCY=2

STREMIO_ADDON_MAX_RESPONSE_BYTES=5242880
STREMIO_ADDON_MAX_REDIRECTS=2
STREMIO_ADDON_ALLOWED_SCHEMES=http,https
STREMIO_ADDON_ALLOW_PRIVATE_HOSTS=false
