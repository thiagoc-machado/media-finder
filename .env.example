APP_NAME=Media Finder
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8091
PUID=1000
PGID=1000
# Replace before starting with APP_ENV=production (for example: openssl rand -hex 32)
APP_SECRET_KEY=replace-with-a-random-64-character-secret
DATABASE_URL=sqlite:////config/media-finder.db
LOG_LEVEL=INFO

SEARCH_QUERY_MIN_LENGTH=2
SEARCH_QUERY_MAX_LENGTH=200
SEARCH_MAX_PROVIDERS=10
SEARCH_PROVIDER_TIMEOUT_SECONDS=5
SEARCH_RESULT_TOKEN_TTL_SECONDS=900
SEARCH_RESULT_STORE_MAX_ITEMS=2000
SEARCH_RATE_LIMIT_REQUESTS=20
SEARCH_RATE_LIMIT_WINDOW_SECONDS=60
SEARCH_HISTORY_PAGE_SIZE=25

QBITTORRENT_URL=http://qbittorrent:8080
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=
QBITTORRENT_CATEGORY_MOVIE=movies
QBITTORRENT_CATEGORY_SERIES=series
QBITTORRENT_CATEGORY_ANIME=
QBITTORRENT_CATEGORY_OTHER=
QBITTORRENT_CONNECT_TIMEOUT_SECONDS=5
QBITTORRENT_OPERATION_TIMEOUT_SECONDS=15
QBITTORRENT_HEALTH_TIMEOUT_SECONDS=5

SONARR_URL=http://sonarr:8989
SONARR_API_KEY=

RADARR_URL=http://radarr:7878
RADARR_API_KEY=

PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=

JACKETT_URL=http://jackett:9117
JACKETT_API_KEY=

TORRENT_INDEXER_URL=http://torrent-indexer:7006
